{
  "name": "@strav/signal",
  "version": "0.3.26",
  "type": "module",
  "description": "Communication layer for the Strav framework \u2014 mail, notifications, broadcasting, and SSE",
  "license": "MIT",
  "keywords": [
    "bun",
    "framework",
    "typescript",
    "strav",
    "mail",
    "notification"
  ],
  "files": [
    "src/",
    "package.json",
    "tsconfig.json",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./mail": "./src/mail/index.ts",
    "./mail/*": "./src/mail/*.ts",
    "./notification": "./src/notification/index.ts",
    "./notification/*": "./src/notification/*.ts",
    "./broadcast": "./src/broadcast/index.ts",
    "./broadcast/*": "./src/broadcast/*.ts",
    "./sse": "./src/sse/index.ts",
    "./sse/*": "./src/sse/*.ts",
    "./providers": "./src/providers/index.ts",
    "./providers/*": "./src/providers/*.ts"
  },
  "peerDependencies": {
    "@strav/kernel": "workspace:*",
    "@strav/http": "workspace:*",
    "@strav/view": "workspace:*",
    "@strav/database": "workspace:*",
    "@strav/queue": "workspace:*"
  },
  "dependencies": {
    "nodemailer": "^6.10.0",
    "@types/nodemailer": "^6.4.0",
    "juice": "^11.0.0",
    "imapflow": "^1.0.190",
    "mailparser": "^3.7.2",
    "@types/mailparser": "^3.4.5"
  },
  "scripts": {
    "test": "bun test tests/",
    "typecheck": "tsc --noEmit"
  }
}

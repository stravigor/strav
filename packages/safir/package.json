{
  "name": "@strav/safir",
  "version": "0.2.2",
  "type": "module",
  "description": "Lightweight Vue 3 UI component library for Stravigor",
  "license": "MIT",
  "keywords": [
    "vue",
    "ui",
    "components",
    "tailwind",
    "stravigor"
  ],
  "files": [
    "src/",
    "package.json",
    "tsconfig.json"
  ],
  "exports": {
